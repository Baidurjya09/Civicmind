# CivicMind — Environment Variables
# Copy to .env and fill in your values

# Hugging Face (for model upload)
HF_TOKEN=your_huggingface_token_here

# Weights & Biases (optional, for training metrics)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=civicmind
WANDB_ENTITY=your_username

# Training
CUDA_VISIBLE_DEVICES=0
TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0  # Adjust for your GPU

# API
API_HOST=0.0.0.0
API_PORT=8080

# Dashboard
DASHBOARD_PORT=8501

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/civicmind.log
